# Base Supabase partagee avec l'Atelier (meme projet).
# En deploiement, ces 3 variables vivent aussi dans Vercel : projet
# aleonmange-site > Settings > Environment Variables (Production + Preview).
SUPABASE_URL=https://yecxgmuryrmztymxjbxo.supabase.co

# Ticket de passerelle (cle anon du projet, dashboard Supabase > Settings > API).
# ZERO droit en base (aucun grant, aucune policy anon) : elle ne sert qu'a
# franchir la passerelle API ; le role effectif vient du JWT ci-dessous.
SUPABASE_ANON_KEY=

# JWT du role Postgres site_lecteur (lecture seule : produit + emplacement,
# RLS active, ecritures refusees par la base). SERVEUR UNIQUEMENT : jamais
# NEXT_PUBLIC, jamais expose au client (grep du bundle a chaque livraison).
# Frappe : site/scripts/frappe-jwt.mjs (exp explicite 10 ans, echeance a
# noter en commentaire ici). Rotation : docs/site/ARCHITECTURE.md.
SUPABASE_SITE_LECTEUR_JWT=
