# Base Supabase partagee avec l'Atelier (meme projet).
# En deploiement, ces 3 variables vivent aussi dans Vercel : projet
# aleonmange-site > Settings > Environment Variables (Production + Preview).
SUPABASE_URL=https://yecxgmuryrmztymxjbxo.supabase.co

# Ticket de passerelle (cle anon du projet, dashboard Supabase > Settings > API).
# ZERO droit en base (aucun grant, aucune policy anon) : elle ne sert qu'a
# franchir la passerelle API ; le role effectif vient du JWT ci-dessous.
SUPABASE_ANON_KEY=

# JWT du role Postgres site_lecteur (lecture seule : produit + emplacement,
# RLS active, ecritures refusees par la base). SERVEUR UNIQUEMENT : jamais
# NEXT_PUBLIC, jamais expose au client (grep du bundle a chaque livraison).
# Frappe : site/scripts/frappe-jwt.mjs (exp explicite 10 ans, echeance a
# noter en commentaire ici). Rotation : docs/site/ARCHITECTURE.md.
SUPABASE_SITE_LECTEUR_JWT=

# --- Vague 2 (ecritures) ---
# JWT du role site_ecrivain (0030) : AUCUN droit table, seulement EXECUTE sur
# les RPC d'ecriture. SERVEUR UNIQUEMENT. Frappe :
#   SUPABASE_JWT_ROLE=site_ecrivain SUPABASE_JWT_SECRET="<secret>" node site/scripts/frappe-jwt.mjs
SUPABASE_SITE_ECRIVAIN_JWT=

# Emails transactionnels (Resend). SERVEUR UNIQUEMENT.
RESEND_API_KEY=
# Mode dev (defaut, RESEND_PROD vide) : envoi depuis le domaine de test Resend
# vers CE destinataire unique, subject prefixe [DEV]. Mettre votre email pour les essais.
RESEND_DEST_TEST=
# aleonmange.app est VERIFIE chez Resend (DKIM+SPF). Mettre "1" en PROD (Vercel
# aleonmange-site, Production) = envoi reel depuis contact@aleonmange.app, reply-to
# aleonmange@yahoo.com, sans prefixe [DEV]. Laisser vide en local = mode dev.
RESEND_PROD=

# --- Mesure d'audience (GA4) ---
# Google Analytics 4, soumis au consentement CNIL (voir Consentement.tsx). ID de
# mesure PUBLIC par nature (prefixe NEXT_PUBLIC, expose au client) : 1re var
# publique du projet. Valeur reelle aussi sur Vercel (aleonmange-site, Production).
NEXT_PUBLIC_GA_ID=G-357NGNS717
