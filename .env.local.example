# Variables d'environnement de l'ATELIER (app a la racine, projet Vercel aleonmange-atelier).
# Le SITE public a son propre exemple : site/.env.local.example.

# --- Base Supabase (meme projet que le site) ---
# Client Atelier (@supabase/ssr, session equipe). Dashboard Supabase > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://yecxgmuryrmztymxjbxo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PAT management (scripts SQL / migrations via l'API management, cf. memoire d'acces).
# Non requis par l'app au runtime ; utile en local pour les migrations.
SUPABASE_MGMT_PAT=

# --- Emails transactionnels ATELIER (Resend) ---
# L'Atelier envoie AU CLIENT la confirmation / le refus d'une commande web
# (src/lib/email.ts, best-effort). MEME cle Resend que le site.
# ATTENTION : ces vars doivent aussi vivre dans le projet Vercel aleonmange-atelier
# (aujourd'hui absentes) sinon CLE vide -> aucun email envoye.
RESEND_API_KEY=
# Mode dev (defaut, RESEND_PROD vide) : envoi vers ce destinataire de test, subject [DEV].
RESEND_DEST_TEST=
# Mettre "1" en PROD (Vercel aleonmange-atelier, Production) : envoi reel depuis
# contact@aleonmange.app, reply-to aleonmange@yahoo.com, sans prefixe [DEV].
RESEND_PROD=
